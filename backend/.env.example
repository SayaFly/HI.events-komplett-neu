APP_NAME="dev.veranstaltungen.de"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Berlin
APP_URL=http://dev.veranstaltungen.de

APP_LOCALE=de
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=event_veranstaltungen
DB_USERNAME=ev_user
DB_PASSWORD=your_secure_password_here

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.dev.veranstaltungen.de

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=ev_

MAIL_MAILER=smtp
MAIL_HOST=mail.dev.veranstaltungen.de
MAIL_PORT=587
MAIL_USERNAME=noreply@dev.veranstaltungen.de
MAIL_PASSWORD=your_mail_password_here
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@dev.veranstaltungen.de"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=dev.veranstaltungen.de

FRONTEND_URL=http://dev.veranstaltungen.de

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
